generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                @id @default(cuid())
  name                String
  nickname            String?
  email               String                @unique
  password            String?
  googleId            String?               @unique @map("google_id")
  picture             String?               @map("avatar")
  role                UserRole              @default(PLAYER)
  xp                  Int                   @default(0)
  level               Int                   @default(1)
  mmr                 Int                   @default(1000)
  fullName            String?
  house               String?
  teamId              String?               @map("team_id")
  createdAt           DateTime              @default(now()) @map("created_at")
  status              String                @default("IDLE")
  currentChallengeId  String?
  lastActionAt        DateTime              @default(now())
  pointsContributed   Int                   @default(0)
  activeSessions      ActiveSession[]
  matchesWon          BattleMatch[]         @relation("MatchesWon")
  bids                Bid[]
  solvedChallenges    ChallengeCompletion[]
  cheatLogs           CheatLog[]
  matchParticipations MatchParticipant[]
  notifications       Notification[]
  paymentsReceived    Payment[]             @relation("PaymentsReceived")
  paymentsMade        Payment[]             @relation("PaymentsMade")
  assignedProjects    Project[]             @relation("AssignedProjects")
  clientProjects      Project[]             @relation("ClientProjects")
  submissions         Submission[]
  teamOwned           Team[]                @relation("TeamOwner")
  joinRequests        TeamJoinRequest[]
  teamMemberships     TeamMember[]
  currentTeam         Team?                 @relation("CurrentTeam", fields: [teamId], references: [id])
}

model Team {
  id             String                @id @default(cuid())
  name           String                @unique
  image          String?
  ownerId        String                @map("owner_id")
  maxMembers     Int                   @default(3) @map("max_members")
  score          Int                   @default(0)
  createdAt      DateTime              @default(now()) @map("created_at")
  activeSessions ActiveSession[]
  completions    ChallengeCompletion[]
  owner          User                  @relation("TeamOwner", fields: [ownerId], references: [id])
  joinRequests   TeamJoinRequest[]
  members        TeamMember[]
  currentMembers User[]                @relation("CurrentTeam")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")
  team     Team     @relation(fields: [teamId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model Contest {
  id          String      @id @default(uuid())
  title       String
  description String?
  tag         String?
  imageUrl    String?
  domain      String
  startTime   DateTime
  endTime     DateTime
  isLive      Boolean     @default(false)
  challenges  Challenge[]
}

model Challenge {
  id             String                @id @default(uuid())
  title          String
  description    String
  category       String                @default("GENERAL")
  difficulty     String                @default("MEDIUM")
  icon           String?
  maxScore       Int                   @default(1000)
  isActive       Boolean               @default(true)
  contestId      String
  activeSessions ActiveSession[]
  matches        BattleMatch[]
  contest        Contest               @relation(fields: [contestId], references: [id])
  completions    ChallengeCompletion[]
  flags          CtfFlag[]
  submissions    Submission[]
}

model Submission {
  id          String    @id @default(uuid())
  userId      String
  challengeId String
  score       Int
  fileUrl     String?
  createdAt   DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model Project {
  id          String    @id @default(uuid())
  title       String
  description String
  budget      Float
  status      String    @default("OPEN")
  clientId    String
  assignedTo  String?
  createdAt   DateTime  @default(now())
  bids        Bid[]
  payments    Payment[]
  assignee    User?     @relation("AssignedProjects", fields: [assignedTo], references: [id])
  client      User      @relation("ClientProjects", fields: [clientId], references: [id])
}

model Bid {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  amount    Float
  proposal  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  projectId String
  payerId   String
  payeeId   String
  amount    Float
  status    String   @default("PENDING")
  stripeId  String?
  createdAt DateTime @default(now())
  payee     User     @relation("PaymentsReceived", fields: [payeeId], references: [id])
  payer     User     @relation("PaymentsMade", fields: [payerId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])
}

model CheatLog {
  id          String   @id @default(uuid())
  userId      String
  contestId   String?
  challengeId String?
  action      String
  details     String?
  severity    String   @default("LOW")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model BattleMatch {
  id           String             @id @default(uuid())
  challengeId  String
  status       String             @default("WAITING")
  winnerId     String?
  createdAt    DateTime           @default(now())
  challenge    Challenge          @relation(fields: [challengeId], references: [id])
  winner       User?              @relation("MatchesWon", fields: [winnerId], references: [id])
  participants MatchParticipant[]
}

model MatchParticipant {
  id      String      @id @default(uuid())
  matchId String
  userId  String
  health  Int         @default(100)
  score   Int         @default(0)
  status  String      @default("ALIVE")
  match   BattleMatch @relation(fields: [matchId], references: [id])
  user    User        @relation(fields: [userId], references: [id])
}

model TournamentBracket {
  id             String    @id @default(uuid())
  tournamentId   String
  round          Int
  matchNumber    Int
  participant1Id String?
  participant2Id String?
  winnerId       String?
  status         String    @default("PENDING")
  scheduledTime  DateTime?
  createdAt      DateTime  @default(now())
}

model CodeExecutionLog {
  id           String   @id @default(uuid())
  submissionId String
  userId       String
  languageId   Int
  sourceCode   String
  stdin        String?
  expectedOut  String?
  stdout       String?
  stderr       String?
  compileOut   String?
  status       String   @default("QUEUED")
  time         Float?
  memory       Int?
  createdAt    DateTime @default(now())
}

model CtfFlag {
  id          String        @id @default(uuid())
  challengeId String
  flag        String
  points      Int
  isDynamic   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  challenge   Challenge     @relation(fields: [challengeId], references: [id])
  captures    FlagCapture[]
}

model FlagCapture {
  id         String   @id @default(uuid())
  flagId     String
  userId     String
  teamId     String?
  capturedAt DateTime @default(now())
  flag       CtfFlag  @relation(fields: [flagId], references: [id])
}

model MatchmakingQueue {
  id       String   @id @default(uuid())
  userId   String
  teamId   String?
  mmr      Int
  gameMode String
  queuedAt DateTime @default(now())
  status   String   @default("SEARCHING")
}

model ActiveSession {
  id          String    @id @default(uuid())
  userId      String
  teamId      String
  challengeId String
  status      String    @default("VIEWING")
  joinedAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  team        Team      @relation(fields: [teamId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, challengeId])
}

model ChallengeCompletion {
  id           String    @id @default(uuid())
  teamId       String
  challengeId  String
  userId       String
  pointsEarned Int
  timeTaken    Int
  completedAt  DateTime  @default(now())
  challenge    Challenge @relation(fields: [challengeId], references: [id])
  team         Team      @relation(fields: [teamId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@unique([teamId, challengeId])
}

model TeamJoinRequest {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")
  team      Team     @relation(fields: [teamId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
}

enum UserRole {
  ADMIN
  PLAYER
}
